    {
      "cities": [
        "Udaipur",
        "Jaipur"
      ],
      "tip": "Fake Tour Guides: A 'friendly' person offers to show you around, then demands a large tip or drags you to overpriced shops. Only use licensed guides (e.g., arranged through your hotel or tourism office)",
      "_source_file": "Rajasthan/All Inclusive Guide- Rajasthan_ Janice.pdf",
      "_source_mtime": 1772384334.7910106
    },
    {
      "cities": [
        "Udaipur",
        "Jaipur"
      ],
      "tip": "Commission Shops: Guides or drivers take you to shops where you are pressured to buy at inflated prices. Shop where you want. Avoid buying immediately—compare prices first. Politely decline offers from unsolicited 'helpers'",
