  "attractions": [
    {
      "name": "Panmen Scenic Area",
      "city": "Suzhou",
      "description": "The complex houses the Pan Gate, the only remaining water-and-land gate in China, along with serene gardens, pavilions, and canals — a perfect introduction to Suzhou's poetic atmosphere",
      "hours": "8:00 AM – 5:00 PM",
      "entry_fee": "CNY 40",
      "recommended_duration": "2-3 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Humble Administrator's Garden",
      "city": "Suzhou",
      "description": "The largest and most famous of Suzhou's classical gardens, it represents the pinnacle of Ming dynasty garden design — tranquil ponds, willow-shaded bridges, and elegant scholar pavilions weave together into a scene that feels timeless",
      "hours": "7:30 AM – 5 PM",
      "entry_fee": "CNY 70 per adult",
      "recommended_duration": "2-3 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Lion Grove Garden",
      "city": "Suzhou",
      "description": "A fascinating maze of limestone rockeries resembling crouching lions, once a retreat for Buddhist monks. Its twisting corridors and grottoes invite exploration, offering the perfect mix of artistry and playfulness",
      "hours": "7:30 AM – 5:00 PM",
      "entry_fee": "CNY 40 per adult",
      "recommended_duration": "1-2 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Pingjiang Road Historic Street",
      "city": "Suzhou",
      "description": "Step back in time on this 800-year-old street flanked by whitewashed houses, tea shops, and boutiques along a tranquil canal. The cobblestone lanes and arched bridges reveal Suzhou's soul — quiet, cultured, and effortlessly graceful",
      "hours": "Open 24 hours",
      "entry_fee": "Free entry",
      "recommended_duration": "2-3 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Suzhou Canal Cruise",
      "city": "Suzhou",
      "description": "Experience the \"Venice of the East\" as you glide along Suzhou's ancient waterways at sunset. Admire stone bridges, willow-lined banks, and illuminated waterfront homes — a poetic close to your day",
      "hours": "5 PM – 8 PM (last cruise at 7:30 PM)",
      "entry_fee": "CNY 120–150 per person",
      "recommended_duration": "1-2 hours",
      "source_files": [
