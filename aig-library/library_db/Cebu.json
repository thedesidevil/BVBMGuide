  "attractions": [
    {
      "name": "Cebu Ocean Park",
      "city": "Cebu",
      "description": "Step into a world of vibrant marine life as you walk through immersive tunnels surrounded by sharks, rays, and tropical fish. The oceanarium offers a calming, almost dreamlike atmosphere with soft blue lighting and slow-moving aquatic life all around you.",
      "hours": "10:00 AM – 6:00 PM",
      "entry_fee": "₹1,200–1,800 per person",
      "recommended_duration": "2–3 hours",
      "source_files": [
        "Philippines/Megha_Philippines_All Inclusive Guide.docx"
      ]
    },
    {
      "name": "Magellan's Cross",
      "city": "Cebu",
      "description": "One of Cebu's most iconic landmarks, this historic cross marks the arrival of Christianity in the Philippines. The painted ceiling above adds a cultural layer, depicting the moment of its planting.",
      "hours": "8:00 AM – 6:00 PM",
      "entry_fee": "Free",
      "recommended_duration": "30 minutes",
      "source_files": [
        "Philippines/Megha_Philippines_All Inclusive Guide.docx"
      ]
    },
    {
      "name": "Basílica del Santo Niño",
      "city": "Cebu",
      "description": "The oldest Roman Catholic church in the country, it carries a deeply spiritual energy with flickering candles and quiet prayer corners. The atmosphere is both reverent and culturally rich.",
      "hours": "6:00 AM – 7:00 PM",
      "entry_fee": "Free",
      "recommended_duration": "45 minutes",
      "source_files": [
        "Philippines/Megha_Philippines_All Inclusive Guide.docx"
      ]
    },
    {
      "name": "Fort San Pedro",
      "city": "Cebu",
      "description": "A compact Spanish-era fort surrounded by greenery, offering a glimpse into Cebu's colonial past. The stone walls and quiet courtyards create a peaceful break from the city bustle.",
      "hours": "8:00 AM – 5:00 PM",
      "entry_fee": "₹50–₹100",
      "recommended_duration": "1 hour",
      "source_files": [
        "Philippines/Megha_Philippines_All Inclusive Guide.docx"
      ]
    },
    {
      "name": "SM Seaside City Cebu",
      "city": "Cebu",
      "description": "One of the largest malls in the Philippines, offering a mix of shopping, cafés, and sea-facing views. A great place to unwind, explore, or pick up essentials in a comfortable setting.",
      "hours": "10:00 AM – 9:00 PM",
      "entry_fee": "Free entry",
      "recommended_duration": "2–3 hours",
      "source_files": [
        "Philippines/Megha_Philippines_All Inclusive Guide.docx"
      ]
    },
    {
      "name": "Anjo World Theme Park",
      "city": "Cebu",
      "description": "Step into a lively, carnival-style atmosphere filled with colorful rides, playful energy, and nostalgic fairground vibes. It's a fun, lighthearted experience perfect for families or anyone looking to add a bit of excitement to the day.",
