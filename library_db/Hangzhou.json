  "attractions": [
    {
      "name": "West Lake",
      "city": "Hangzhou",
      "description": "Lose yourself along willow-lined paths and mirror-like waters that have inspired poets for centuries. The lake's tranquil charm, dotted with arched bridges, lotus ponds, and traditional teahouses, captures the essence of Chinese beauty and harmony",
      "hours": "7 AM – 8 PM (open area)",
      "entry_fee": "Free entry",
      "recommended_duration": "3-4 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Leifeng Pagoda",
      "city": "Hangzhou",
      "description": "A striking five-story pagoda overlooking West Lake, Leifeng is steeped in legend — said to be the setting of the \"Legend of the White Snake,\" one of China's most beloved love stories. From its terraces, enjoy panoramic views of the shimmering lake and distant mountains",
      "hours": "8:00 AM – 5:30 PM",
      "entry_fee": "CNY 40 per adult",
      "recommended_duration": "1-2 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "West Lake Cruise",
      "city": "Hangzhou",
      "description": "Board a traditional painted boat to drift across the lake's calm waters. Pass by iconic spots like Three Pools Mirroring the Moon and Su Causeway, where reflections of willow trees shimmer on the surface",
      "hours": "8 AM – 5 PM (departures every 30 minutes)",
      "entry_fee": "CNY 55–90 pp depending on boat type",
      "recommended_duration": "1 hour",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Yunqi Zhujing",
      "city": "Hangzhou",
      "description": "Escape into tranquility at this bamboo forest trail just outside the city center. The air feels cooler and greener beneath thousands of slender stalks swaying softly in the wind — a place to slow down and soak in nature's rhythm",
      "hours": "7 AM – 5 PM",
      "entry_fee": "Free entry",
      "recommended_duration": "2-3 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    }
  ],
