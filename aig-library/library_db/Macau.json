  "attractions": [
    {
      "name": "Lou Lim Ieoc Garden",
      "city": "Macau",
      "description": "One of Macau's few classical Chinese gardens, Lou Lim Ieoc combines winding bridges, koi ponds, and elegant pavilions — a tranquil oasis reflecting Suzhou-style design with subtle Portuguese touches",
      "hours": "6 AM – 9 AM",
      "entry_fee": "Free entry",
      "recommended_duration": "1-2 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Macau Tower",
      "city": "Macau",
      "description": "Standing 338 meters tall, the Macau Tower offers sweeping views across the Pearl River Delta. You can simply enjoy sunset vistas from the Observation Deck or, for thrill-seekers, experience the Skywalk X or Bungee Jump — among the world's highest",
      "hours": "10 AM – 9 PM",
      "entry_fee": "Observation Deck: MOP 208 per adult",
      "recommended_duration": "1-2 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Senado Square",
      "city": "Macau",
      "description": "The beating heart of old Macau, this European-style square is lined with wave-patterned mosaic tiles, neoclassical buildings, and charming arcades. The square is especially lively in the mornings, filled with cafés and boutique shops",
      "hours": "Open 24 hours",
      "entry_fee": "Free entry",
      "recommended_duration": "1-2 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "St. Dominic's Church",
      "city": "Macau",
      "description": "Founded in 1587 by Spanish Dominican friars, this Baroque church with its buttery-yellow façade and green shutters is one of the oldest in Asia. Step inside for a peaceful contrast to the bustle outside — sunlight filters through stained glass, casting colorful reflections on the marble floors",
      "hours": "10 AM – 6 PM",
      "entry_fee": "Free entry",
      "recommended_duration": "30 minutes",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Ruins of St. Paul's",
      "city": "Macau",
      "description": "The most iconic landmark of Macau — only the stone façade remains of the 17th-century Church of St. Paul, but it stands proudly above a wide staircase as a symbol of Macau's enduring blend of East and West",
      "hours": "9 AM – 6 PM",
      "entry_fee": "Free entry",
      "recommended_duration": "30 minutes",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Monte Fort",
      "city": "Macau",
      "description": "Adjacent to the Ruins of St. Paul's, this 17th-century fortress once protected the city from pirates. Today, its stone ramparts offer panoramic views of Macau's skyline — a perfect vantage point for photos",
      "hours": "7 AM – 7 PM",
      "entry_fee": "Free entry",
      "recommended_duration": "1 hour",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Coloane Village",
      "city": "Macau",
      "description": "A quaint seaside village known for its Portuguese-style houses, small chapels, and waterfront cafés. Stroll through its cobblestone lanes, admire colorful tiled façades, and breathe in the ocean breeze",
      "hours": "Open area, best visited 9 AM – 12 PM",
      "entry_fee": "Free entry",
      "recommended_duration": "2-3 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Chapel of St. Francis Xavier",
      "city": "Macau",
      "description": "Built in 1928, this yellow-and-white chapel overlooks the sea and houses relics of early Christian missionaries. A picture-perfect landmark with striking Portuguese-Baroque architecture",
      "hours": "10 AM – 5 PM",
      "entry_fee": "Free entry",
      "recommended_duration": "30 minutes",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    },
    {
      "name": "Taipa Village",
      "city": "Macau",
      "description": "A delightful blend of old-world charm and modern creativity. Explore narrow lanes filled with pastel colonial homes, indie galleries, and artisanal dessert shops. Don't miss the Taipa Houses Museum, showcasing 1920s Portuguese architecture",
      "hours": "10 AM – 6 PM",
      "entry_fee": "Free entry",
      "recommended_duration": "2-3 hours",
      "source_files": [
        "China/Sanjeev-All Inclusive Guide_China.pdf"
      ]
    }
