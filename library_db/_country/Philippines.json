  "connectivity_tips": [
    {
      "cities": [
        "Philippines"
      ],
      "tip": "The Philippines has good mobile coverage in Cebu, especially in resort areas (Mactan) and city areas, but speeds may vary during island hopping or remote coastal areas.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Globe Telecom Philippines: Strong coverage in urban & resort areas, good data packages for tourists, widely available at airport & malls.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Smart Communications Philippines: Slightly better in remote/island areas, reliable for island hopping days, competitive prepaid data plans.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "SIM cards available at Mactan-Cebu International Airport upon arrival with quick setup and tourist-friendly packages for approximately ₹800–1,500 depending on data.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Mall purchase alternative at Ayala Center Cebu with more plan options and staff assistance available.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "eSIM option highly recommended for convenience - activate before departure (no need to swap physical SIM), ideal for seamless connectivity from landing. Popular platforms: Airalo, Nomad.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Passport mandatory for SIM registration with quick form fill at purchase.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "5–10 GB data sufficient for maps & navigation, WhatsApp/calls, social media uploads, and ride bookings.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Both resorts offer strong Wi-Fi connectivity. Also available in cafés, malls, and restaurants.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    }
  ],
  "safety_tips": [
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Warm & polite greetings go a long way. Filipinos are known for their warmth and hospitality. A simple smile and polite tone are always appreciated.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Tipping culture: Not mandatory, but widely appreciated. Restaurants: 5–10% (if service charge not included). Hotel staff/drivers: Small tips (₹100–300 equivalent).",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Dress code awareness: Resorts & beaches - casual wear is fine. Churches & religious sites - wear covered shoulders & knees, avoid very short or revealing outfits.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Respect at religious sites: At places like Basilica del Santo Niño Cebu - maintain quiet, respectful tone, avoid flash photography inside, follow local cues.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Taxi & transport etiquette: Taxi drivers are generally honest and helpful. Prefer cash payments (Philippine Peso), confirm destination clearly before starting.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Dining etiquette: Sharing food is common in Filipino culture. It's polite to wait until everyone is served before eating. Vegetarian requests should be clearly explained.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    }
  ],
  "health_tips": [
    {
      "cities": [
        "Philippines"
      ],
      "tip": "No special or mandatory vaccines required for travel to Cebu, but routine vaccinations (Tetanus, Measles, Mumps, Rubella, Influenza) should be up-to-date.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Travel-recommended vaccines: Hepatitis A (recommended due to food and water exposure risk), Typhoid (advisable, especially if trying local food outside resorts). These are precautionary, not compulsory.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Food & water safety: Prefer freshly cooked, hot meals and stick to resort dining or well-rated restaurants.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "For vegetarian travellers: Clearly mention 'No meat, no fish, no oyster sauce' and prefer resort restaurants or international cafés. Carry ready-to-eat backup snacks for convenience.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Swimming & water activity safety: Shower after pool/beach use, avoid swallowing pool or seawater, use reef-safe sunscreen during island hopping.",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    },
    {
      "cities": [
        "Philippines"
      ],
      "tip": "Basic medicines to carry: Personal prescription medications, Paracetamol/fever relief, ORS/hydration salts, Anti-allergy tablets, Motion sickness medication (for island hopping), Basic first-aid kit (band-aids, antiseptic).",
      "_source_file": "Philippines/Megha_Philippines_All Inclusive Guide.docx",
      "_source_mtime": 1773790224.0
    }
  ],
